extends base

block title
  title= page.title + ' | ' + config.title

block content
  -
    // 从路径提取 MM-DD（例如 'almanac/10-30.html' 或 'almanac/10-30/index.html'）
    const p = page.path || '';
    const m = p.match(/almanac\/(\d{2}-\d{2})(?:\/|\.html)/);
    const key = m ? m[1] : '01-01';

    // 用 2000 年做平移（闰年稳）
    function shiftKey(k, delta){
      const [mm, dd] = k.split('-').map(Number);
      const base = new Date(Date.UTC(2000, mm - 1, dd, 12, 0, 0));
      base.setUTCDate(base.getUTCDate() + delta);
      const m2 = String(base.getUTCMonth() + 1).padStart(2,'0');
      const d2 = String(base.getUTCDate()).padStart(2,'0');
      return `${m2}-${d2}`;
    }
    function zhTitle(k){
      const [m, d] = k.split('-');
      return `${String(Number(m))} 月 ${String(Number(d))} 日`;
    }
    const prevKey = shiftKey(key, -1);
    const nextKey = shiftKey(key, +1);
    const baseUrl = url_for('/').replace(/\/+$/, '');

    const h2Count = (page.content && page.content.match(/<h2\b[^>]*>/gi) || []).length;


  .post
    //- 页头：标题 + 导航
    header.flex.items-center.justify-between
      h1.post-title= zhTitle(key)
          if h2Count
            span.almanac-h2count(title=`共 ${h2Count} 个小节`) #{h2Count}
      nav.post-meta-almanac
        a(href=`${baseUrl}/almanac/${prevKey}/`).post-nav-link Pre
        span &nbsp;|&nbsp;
        a(href="javascript:;" onclick="gotoToday()").post-nav-link Now
        span &nbsp;|&nbsp;
        a(href=`${baseUrl}/almanac/${nextKey}/`).post-nav-link Next
        form#goto-almanac(onsubmit="return gotoAlmanac(this);")
          .almanac-group
            input#almanac-input.almanac-input(
              type="text"
              placeholder="MMDD"
              aria-label="跳转到某天（MMDD）"
              maxlength="4"
              inputmode="numeric"
              pattern="\\d{3,4}"  
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
            )
            button.almanac-btn(type="submit") Go



    //- 若需目录（按二级标题年份），沿用主题的 toc 开关
    if page.toc
      .clear
        #toc.toc-article
          .toc-title= __('contents')
          != toc(page.content, {list_number: theme.toc_number})

    //- 正文：渲染 MM-DD.md（## 2026 / ## 2025 …）
    .post-content
      != page.content
    
    //- 如果有 h2 小节，则在页尾显示导航条
    if h2Count
      nav.post-meta-almanac
          a(href=`${baseUrl}/almanac/${prevKey}/`).post-nav-link Pre
          span &nbsp;|&nbsp;
          a(href="javascript:;" onclick="gotoToday()").post-nav-link Now
          span &nbsp;|&nbsp;
          a(href=`${baseUrl}/almanac/${nextKey}/`).post-nav-link Next
          form#goto-almanac(onsubmit="return gotoAlmanac(this);")
            .almanac-group
              input#almanac-input.almanac-input(
                type="text"
                placeholder="MMDD"
                aria-label="跳转到某天（MMDD）"
                maxlength="4"
                inputmode="numeric"
                pattern="\\d{3,4}"  
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
              )
              button.almanac-btn(type="submit") Go

    //- ▼ 新增：跳转逻辑（复用上面算好的 baseUrl）
    script.
      (function(){
        var BASE = '!{baseUrl}';
        function pad2(n){ return String(n).padStart(2,'0'); }
        function validMD(mm, dd){
          // 用 2000-??-?? 校验闰年与日期合法
          var d = new Date(Date.UTC(2000, mm - 1, dd, 12, 0, 0));
          return (d.getUTCMonth() + 1) === mm && d.getUTCDate() === dd;
        }

        window.gotoToday = function(){
          try {
            var fmt = new Intl.DateTimeFormat('de-DE', {
              timeZone: 'Asia/Shanghai',
              year: 'numeric', month: '2-digit', day: '2-digit'
            });
            var parts = fmt.formatToParts(new Date());
            var by = {};
            parts.forEach(p => by[p.type] = p.value);
            var mm = by.month;
            var dd = by.day;
            var key = mm + '-' + dd;
            location.href = (BASE + '/almanac/' + key + '/').replace(/\/{2,}/g, '/');
          } catch(e) {
            var d = new Date();
            var m = String(d.getMonth()+1).padStart(2,'0');
            var d2 = String(d.getDate()).padStart(2,'0');
            location.href = (BASE + '/almanac/' + m + '-' + d2 + '/').replace(/\/{2,}/g, '/');
          }
        };

        // 允许在表单里输入 MMDD 并跳转
        window.gotoAlmanac = function(form){
          var input = form.querySelector('input');
          var v = (input.value || '').trim();
          if (!v) return false;

          // 允许纯数字：MMDD 或 MDD（如 703 → 07-03）
          var m = v.match(/^(\d{3,4})$/);
          if (!m) { 
            alert('请输入形如 MMDD 的数字（如 703 或 1129）'); 
            return false; 
          }

          var digits = m[1];
          var mm, dd;
          if (digits.length === 3) { // 703 → 07-03
            mm = +digits[0];
            dd = +digits.slice(1);
          } else { // 0703 → 07-03
            mm = +digits.slice(0, 2);
            dd = +digits.slice(2);
          }

          if (!validMD(mm, dd)) { 
            alert('无效日期'); 
            return false; 
          }

          var key = pad2(mm) + '-' + pad2(dd);
          location.href = (BASE + '/almanac/' + key + '/').replace(/\/{2,}/g, '/');
          return false; // 阻止表单默认提交
        };

        // ==== 新增：左右方向键快捷导航 ====
        var PRE  = (BASE + '/almanac/!{prevKey}/').replace(/\/{2,}/g, '/');
        var NEXT = (BASE + '/almanac/!{nextKey}/').replace(/\/{2,}/g, '/');

        function isEditableTarget(el){
          if (!el) return false;
          if (el.isContentEditable) return true;
          var tag = (el.tagName || '').toUpperCase();
          return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
        }

        document.addEventListener('keydown', function(e){
          // 忽略被其它逻辑捕获、含修饰键、或正处于可编辑区域的按键
          if (e.defaultPrevented) return;
          if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
          if (isEditableTarget(e.target)) return;

          if (e.key === 'ArrowLeft') {
            e.preventDefault();
            location.href = PRE;
          } else if (e.key === 'ArrowRight') {
            e.preventDefault();
            location.href = NEXT;
          }
        });
      })();

