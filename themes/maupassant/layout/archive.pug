//- 这一页是每个具体标签指向的页面


extends base

block title
  if page.category
    title= page.category + ' | ' + config.title
  if page.tag
    title= page.tag + ' | ' + config.title
  if page.archive
    title= __('archive') + ' | ' + config.title
block content
  .post
      h1.post-title= 'Tags'
      .post-content
        .tagcloud
          for tag in site.tags.toArray().sort(function(a, b) { return b.length - a.length; })
            - var isCurrentTag = (tag.name === page.tag)
            a(href= config.root + 'tags/' + tag.name, title=tag.name, rel= tag.length, class= isCurrentTag ? 'current-tag' : '') #{tag.name}
  //- if page.category || page.tag
  //-   h1.label-title=  __( page.category || page.tag)

  .post
    .post-archive
      - var allposts = page.posts.toArray().sort(function(a, b) { return b.date - a.date; }).reduce((r, v, i, a, k = -v.date.format('YYYY')) => ((r[k] || (r[k] = [])).push(v), r), {})
      each posts, year in allposts
        h2
          div.archive-year-count-container
            span.year-text= -year
            span.post-count-year= ' ' + posts.length
        ul.listing
          for post in posts
            li
              span.date= post.date.format(config.date_format)
              a(href=url_for(post.path), title=post.title)
                +title(post)
  include _partial/paginator.pug
